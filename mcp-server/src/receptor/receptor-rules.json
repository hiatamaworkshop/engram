{
  "$schema": "Passive receptor method definitions. See docs/PASSIVE_RECEPTOR_DESIGN.md",
  "methods": [
    {
      "id": "engram_probe",
      "type": "knowledge_search",
      "mode": "auto",
      "trigger": {
        "signals": ["compound_frustration_hunger"],
        "states": ["stuck"],
        "sensitivity": 0.7,
        "frequency": "low"
      },
      "action": {
        "tool": "engram_pull",
        "args": { "projectId": "auto" },
        "output": { "targets": ["hotmemo", "log"], "format": "summary", "maxLength": 300 }
      }
    },
    {
      "id": "mycelium_filter",
      "type": "knowledge_search",
      "mode": "background",
      "trigger": {
        "signals": ["frustration_spike", "uncertainty_sustained"],
        "states": ["stuck", "exploring"],
        "sensitivity": 0.6,
        "frequency": "low"
      },
      "action": {
        "tool": "mycelium_filter",
        "args": {
          "sourceQdrantUrl": "http://localhost:6333",
          "collections": "engram",
          "runs": 3,
          "format": "summary"
        },
        "output": { "targets": ["subsystem", "file", "log"], "format": "summary", "maxLength": 300 }
      }
    },
    {
      "id": "frustration_alert",
      "type": "status_notify",
      "mode": "notify",
      "trigger": {
        "signals": ["frustration_spike", "compound_frustration_hunger"],
        "states": ["stuck", "exploring"],
        "sensitivity": 0.8,
        "frequency": "low"
      },
      "action": {
        "message": "frustration sustained — consider changing approach"
      }
    },
    {
      "id": "fatigue_warning",
      "type": "status_notify",
      "mode": "notify",
      "trigger": {
        "signals": ["fatigue_rising"],
        "states": ["stuck", "exploring", "deep_work"],
        "sensitivity": 0.6,
        "frequency": "low"
      },
      "action": {
        "message": "fatigue accumulating — session checkpoint recommended"
      }
    },
    {
      "id": "engram_probe_light",
      "type": "knowledge_search",
      "mode": "auto",
      "trigger": {
        "signals": ["frustration_spike", "hunger_spike"],
        "states": ["stuck", "exploring"],
        "sensitivity": 0.4,
        "frequency": "medium"
      },
      "action": {
        "tool": "engram_pull",
        "args": { "projectId": "auto" },
        "output": { "targets": ["hotmemo"], "format": "summary", "maxLength": 200 }
      }
    },
    {
      "id": "path_suggest",
      "type": "context_assist",
      "mode": "auto",
      "trigger": {
        "signals": ["hunger_spike", "uncertainty_sustained"],
        "states": ["exploring", "stuck"],
        "sensitivity": 0.5,
        "frequency": "medium"
      },
      "action": {
        "tool": "path_suggest",
        "output": { "targets": ["file"], "format": "json" }
      }
    },
    {
      "id": "context_snapshot",
      "type": "context_persist",
      "mode": "auto",
      "trigger": {
        "signals": ["confidence_sustained"],
        "states": ["deep_work"],
        "sensitivity": 0.6,
        "frequency": "low"
      },
      "action": {
        "tool": "engram_context_push",
        "output": { "targets": ["file", "log"], "format": "summary", "maxLength": 300 }
      }
    },
    {
      "id": "engram_push_reminder",
      "type": "knowledge_persist",
      "mode": "notify",
      "trigger": {
        "signals": ["confidence_sustained"],
        "states": ["deep_work", "exploring"],
        "sensitivity": 0.5,
        "frequency": "low"
      },
      "action": {
        "message": "confidence high — good moment to engram_push current findings"
      }
    },
    {
      "id": "action_logger",
      "type": "observation",
      "mode": "background",
      "trigger": {
        "signals": ["*"],
        "states": ["stuck", "exploring", "deep_work", "idle"],
        "sensitivity": 0.1,
        "frequency": "high"
      },
      "action": {
        "tool": "action_logger",
        "output": { "targets": ["log"], "format": "json" }
      }
    }
  ]
}
