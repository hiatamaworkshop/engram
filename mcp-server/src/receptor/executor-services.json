{
  "$schema": "External executor definitions. Loaded at startup, registered into service registry.",
  "services": [
    {
      "tool": "mycelium_filter",
      "type": "mcp",
      "server": {
        "command": "node",
        "args": ["dist/server.js"],
        "cwd": "../../../../mycelium_universal"
      }
    },
    {
      "tool": "mycelium_status",
      "type": "mcp",
      "server": {
        "command": "node",
        "args": ["dist/server.js"],
        "cwd": "../../../../mycelium_universal"
      }
    }
  ]
}