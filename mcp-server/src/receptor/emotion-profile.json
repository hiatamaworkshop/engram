{
  "$schema": "Emotion engine numeric profile. Single source of truth for all receptor tuning constants.",

  "accumulator": {
    "halfLife": {
      "frustration": 180000,
      "seeking": 210000,
      "confidence": 120000,
      "fatigue": 600000,
      "flow": 180000
    },
    "idleFreezeMs": 180000,
    "interTurnCapMs": 30000
  },

  "impulse": {
    "event": {
      "shell_exec.failure":  { "frustration": 0.10, "confidence": -0.04 },
      "shell_exec.success":  { "confidence": 0.08, "flow": 0.04, "frustration": -0.08, "seeking": 0.03 },
      "file_edit":           { "confidence": 0.04, "seeking": 0.02, "flow": 0.02 },
      "search.empty":        { "seeking": -0.10 },
      "search.found":        { "seeking": 0.05 },
      "file_read":           { "seeking": -0.02 },
      "memory_read":         { "seeking": -0.02 },
      "memory_write":        { "confidence": 0.03 },
      "user_prompt":         { "fatigue": -0.02 },
      "user_prompt.long":    { "seeking": 0.02, "confidence": 0.01 }
    },
    "pattern": {
      "trial_error":     { "frustration": 0.08 },
      "wandering":       { "seeking": -0.12 },
      "exploration":     { "seeking": -0.04 },
      "implementation":  { "flow": 0.04, "confidence": 0.04 }
    },
    "heatmapShift": { "seeking": -0.08 },
    "fatigue": {
      "base": 0.005,
      "hourlyRate": 0.003
    }
  },

  "signal": {
    "defaultThreshold": 0.6,
    "holdReleaseCount": 3,
    "compounds": [
      {
        "id": "compound_frustration_seeking",
        "requires": ["frustration", "seeking"],
        "seekingSign": "negative",
        "intensity": "max",
        "priority": true
      }
    ]
  },

  "ambient": {
    "timeConstantMs": 600000,
    "silenceGateMs": 180000,
    "silenceFloor": 0.05,
    "offsets": {
      "frustration": 0.20,
      "seeking": 0.25,
      "confidence": 0.25,
      "fatigue": 0.30,
      "flow": 0.20
    },
    "minThreshold": 0.25,
    "maxThreshold": 0.85
  },

  "meta": {
    "bufferSize": 20,
    "dangerHitRate": 0.5,
    "safeHitRate": 0.2,
    "maxFieldAdjustment": 0.15,
    "adjustmentStep": 0.03,
    "flowDisruption": {
      "ratio": 0.3,
      "threshold": 0.3
    },
    "stateThresholds": {
      "stuck":     { "axis": "frustration", "min": 0.25, "pattern": "trial_error" },
      "deep_work": { "axis": "flow",        "min": 0.15, "pattern": "implementation" }
    }
  }
}
